POSTGRES_USER=aibadges
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aibadges
DATABASE_URL=postgresql+asyncpg://aibadges:changeme@db:5432/aibadges

JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

UPLOAD_DIR=/app/uploads
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost"]

# Ollama base URL. Backend reaches Ollama on the host at this URL.
# Used for model discovery (/api/tags) and chat calls (/api/chat).
OLLAMA_BASE_URL=http://host.docker.internal:11434

NEXT_PUBLIC_API_URL=http://localhost/api
